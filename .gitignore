.env
.env.*
!.env.example

# ── HuggingFace model cache (large) ────────────────────────────────────────
.cache/

# ── IDE ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
